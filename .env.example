APP_PORT=3000
SOCKET_PORT=3001
APP_ENV=development
NODE_ENV=development

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
SOCKET_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
SOCKET_WEBSOCKET_ONLY=false

DATABASE_URL=postgres://postgres:postgres@localhost:5432/bomb-barbers

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_TTL_SECONDS=604800

# Proteksi autentikasi
AUTH_LOGIN_RATE_LIMIT_MAX=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_REFRESH_RATE_LIMIT_MAX=20
AUTH_REFRESH_RATE_LIMIT_WINDOW_SECONDS=60

REDIS_URL=redis://localhost:6379

# Supabase Storage
SUPABASE_PRIVATE_MEDIA_BUCKET=bomb-private-media
SUPABASE_PUBLIC_MEDIA_BUCKET=bomb-public-media
MEDIA_SIGNED_URL_TTL_SECONDS=3600
MEDIA_MAX_WIDTH=6000
MEDIA_MAX_HEIGHT=6000
MEDIA_MAX_PIXELS=25000000

# Tracking realtime
TRACKING_LOCATION_TTL_SECONDS=120
TRACKING_SESSION_TTL_SECONDS=14400
TRACKING_MAX_LOCATION_AGE_MS=120000
TRACKING_MAX_FUTURE_SKEW_MS=30000
TRACKING_RATE_LIMIT_MAX=10
TRACKING_RATE_LIMIT_WINDOW_SECONDS=2
TRACKING_FALLBACK_SPEED_KMH=25
ROUTING_API_URL=
ROUTING_API_TOKEN=

# Development/test dapat menjalankan worker di proses API. Production sebaiknya
# menjalankan `bun run worker` sebagai proses terpisah.
RUN_WORKERS_IN_PROCESS=false

# Integritas booking dan timeout appointment
ORDER_ACCEPTANCE_TIMEOUT_MINUTES=60
APPOINTMENT_NO_SHOW_GRACE_MINUTES=15
HOME_SERVICE_TRAVEL_BUFFER_MINUTES=15

# Payment Gateway — Midtrans
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
MIDTRANS_IS_PRODUCTION=false
