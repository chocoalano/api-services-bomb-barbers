{
  "name": "api-services",
  "version": "1.0.50",
  "scripts": {
    "start": "NODE_ENV=production PROCESS_ROLE=api bun run src/server.ts",
    "dev": "bun run --watch src/server.ts",
    "worker": "NODE_ENV=production PROCESS_ROLE=worker bun run src/worker.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "db:reset": "bun run src/db/reset.ts",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts",
    "db:seed:starter": "bun run src/db/seed.ts --starter"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/static": "^1.4.10",
    "@elysiajs/stream": "^1.1.0",
    "@elysiajs/swagger": "^1.3.1",
    "@sinclair/typebox": "^0.34.49",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supabase/supabase-js": "^2.108.0",
    "@types/sharp": "^0.32.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.78.0",
    "elysia": "latest",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "rotating-file-stream": "^3.2.9",
    "sharp": "^0.35.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "bun-types": "latest",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3"
  },
  "module": "src/index.js"
}
